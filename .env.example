# MVP env example
# Do not commit real secrets.

# Local app
APP_ENV=development
APP_PORT=3000

# n8n local/self-hosted
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_USERNAME=
N8N_PASSWORD=

# Future data layer placeholders
DATABASE_URL=

# Telegram API credentials
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
# Optional: persist session string instead of file
TELEGRAM_SESSION=

# OpenAI API key (used for assessment AI and pain extraction)
OPENAI_API_KEY=

# Optional: custom data directory (default: ../data relative to app/)
# DATA_DIR=
